<?xml version="1.0" encoding="utf-8"?>
<!-- Round badge behind the empty-state icon: a white ring around a faint indigo disc,
     so the glyph reads as a designed mark rather than a bare icon. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
    <item
        android:left="10dp"
        android:top="10dp"
        android:right="10dp"
        android:bottom="10dp">
        <shape android:shape="oval">
            <solid android:color="#E8EAF6" />
        </shape>
    </item>
</layer-list>

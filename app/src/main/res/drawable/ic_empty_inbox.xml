<?xml version="1.0" encoding="utf-8"?>
<!-- Empty-state glyph: an arrow dropping into an open tray ("save something here").
     Stroked line-art so it renders identically on every device (replaces the old emoji). -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- Down arrow -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#1A237E"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M12,4 L12,13.5" />
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#1A237E"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M8,9.5 L12,13.5 L16,9.5" />
    <!-- Open tray -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#1A237E"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M5,14.5 L5,19 L19,19 L19,14.5" />
</vector>

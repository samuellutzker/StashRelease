<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/colorPrimary"
            app:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <Switch
                android:id="@+id/switchSyncEnabled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enable sync"
                android:textSize="16sp"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Server hostname or IP"
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etHost"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. 192.168.1.100"
                android:inputType="textUri"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Port"
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etPort"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="9876"
                android:inputType="number"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Password"
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Leave blank to keep existing"
                android:inputType="textPassword"
                android:layout_marginBottom="16dp" />

            <CheckBox
                android:id="@+id/cbDownloadAll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Auto-Download"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="When enabled, all files stored on the server are automatically downloaded whenever they become available."
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="16dp" />

            <CheckBox
                android:id="@+id/cbUseTls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Use TLS (wss://)"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Encrypts the connection. For a self-signed server certificate, the cert is trusted on first connect and pinned — run Test Connection and check the shown fingerprint matches the server's."
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="24dp" />

            <Button
                android:id="@+id/btnScanQr"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Scan QR Code"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnResetFingerprint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Reset Pinned Certificate"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnTestConnection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Test Connection"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnAbout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="About &amp; Support"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary" />

        </LinearLayout>
    </ScrollView>

    <!-- Save is pinned below the scroll so it stays visible no matter how long the form grows. -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/colorDivider" />

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save"
        android:layout_margin="16dp" />

</LinearLayout>
